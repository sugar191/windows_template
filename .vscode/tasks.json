{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build EXE",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "PyInstaller",
                "--onefile",
                "--noconsole",
                "--name",
                "${workspaceFolderBasename}",
                // アイコンを設定する場合は以下3行のコメントを外してください（assets/icon.ico を用意する）
                // "--icon=${workspaceFolder}/assets/icon.ico",
                // "--add-data=${workspaceFolder}/assets:assets",
                "main.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
